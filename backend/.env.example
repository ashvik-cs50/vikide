# ─── Database ───
# Railway will auto-provide this when you attach PostgreSQL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/vik_ide

# ─── Authentication ───
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ─── CORS ───
# The URL of your frontend (GitHub Pages or custom domain)
FRONTEND_URL=https://vikco.qzz.io

# ─── Server ───
PORT=3001
