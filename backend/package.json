{
  "name": "vikide-api",
  "version": "1.0.0",
  "description": "VIK IDE Backend - Cloudflare Workers + D1 (SQLite)",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate": "wrangler d1 migrations apply vikide-db --remote",
    "db:seed": "wrangler d1 execute vikide-db --remote --file=seed.sql",
    "db:init-local": "wrangler d1 migrations apply vikide-db --local",
    "db:seed-local": "wrangler d1 execute vikide-db --local --file=seed.sql"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
